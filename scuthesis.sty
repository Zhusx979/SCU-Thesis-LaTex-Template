% setting up the abstract
\newcommand{\varKeyword}{}
\newcommand{\keyword}[1]{\renewcommand{\varKeyword}{#1}}
\newcommand{\CenteredTitleBlock}[2]{%
\begin{center}
\parbox{#1}{\centering #2}
\end{center}
}
\renewenvironment{abstract}[1]{
\addtolength{\leftskip}{1.1cm}
\addtolength{\rightskip}{1.1cm}
\thispagestyle{empty}
\addtocounter{page}{-1}
\vspace*{1cm}
\CenteredTitleBlock{0.88\textwidth}{\heiti \zihao{-2} \textbf{\varTitle}}
\vspace{1cm}
\centerline{\kaishu \zihao{4} \varCollege}
\vspace{1cm}
\centerline{\kaishu \zihao{4} \varStudentLabel:\varAuthor \hspace{1cm} \varAdviserLabel:\varAdviser}
\vspace{1.2cm}
\kaishu \zihao{5}
\textbf{[摘要]} \keyword{#1} }
{\par \textbf{[主题词]} \varKeyword \clearpage}
\newenvironment{abstractEng}[1]{
\addtolength{\leftskip}{1.1cm}
\addtolength{\rightskip}{1.1cm}
\thispagestyle{empty}
\addtocounter{page}{-1}
\vspace*{1cm}
\CenteredTitleBlock{0.88\textwidth}{\heiti \zihao{-2} \textbf{\varTitleEng}}
\vspace{1cm}
\centerline{\kaishu \zihao{4} \varCollegeEng}
\vspace{1cm}
\centerline{\kaishu \zihao{4} \varStudentLabelEng:\varAuthorEng \hspace{1cm} \varAdviserLabelEng:\varAdviserEng}
\vspace{1.2cm}
\kaishu \zihao{5} 
\textbf{[Abstract]} \keyword{#1} }
{\par \textbf{[Key Words]} \varKeyword \clearpage}

